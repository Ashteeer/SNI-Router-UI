# SNI-Router UI — agent config (LOCAL to this managed host).
# Written by scripts/install-agent.sh; edited here or re-run the installer.
# Plain KEY=VALUE so systemd can load it with EnvironmentFile=.
# This file is NOT editable from the web UI — it lives on the remote host.

# Bearer token clients must send as `Authorization: Bearer <token>`.
# Generated by the installer; must match the host's token stored in the UI.
SNI_AGENT_TOKEN=CHANGE_ME

# Interface to listen on. 0.0.0.0 = all; use 127.0.0.1 if the UI is co-located.
SNI_AGENT_BIND=0.0.0.0

# TCP port for GET /sys.
SNI_AGENT_PORT=9110
